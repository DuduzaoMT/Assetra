# Build stage - Compile Go binary
FROM golang:1.25-alpine AS builder

# Install dependencies needed for build
RUN apk add --no-cache git

# Set working directory
WORKDIR /app

# Copy go.mod and go.sum first to leverage Docker cache
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Build authentication service
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o authsvc ./authentication/

# Runtime stage - Final optimized image
FROM alpine:3.19

# Add SSL certificates and timezone data
RUN apk --no-cache add ca-certificates tzdata

# Create non-root user for security
RUN adduser -D -s /bin/sh app

# Set working directory
WORKDIR /app

# Copy binary from build stage
COPY --from=builder /app/authsvc .

# Set correct ownership
RUN chown app:app /app/authsvc

# Switch to non-root user
USER app

# Expose service port
EXPOSE 9000

# Command to run the application
CMD ["./authsvc"]